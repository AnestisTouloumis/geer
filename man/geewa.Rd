fitted_model_brgee_robust <- update(fitted_model_gee, method = "brgee-robust")
summary(fitted_model_brgee_robust, cov_type = "bias-corrected")

fitted_model_brgee_naive <- update(fitted_model_gee, method = "brgee-naive")
